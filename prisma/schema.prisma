// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Confession {
  id              Int      @id @default(autoincrement())
  text            String
  status          String   @default("pending") // pending | approved | posted
  number          Int?     // confession number e.g. 145
  parts           String   @default("[]") // JSON array of text parts
  imageUrls       String   @default("[]") // JSON array of generated image URLs
  igPostId        String?  // Instagram post ID after publishing
  igPermalink     String?  // Instagram permalink
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt hash
  createdAt DateTime @default(now())
}

model Counter {
  id    Int @id @default(autoincrement())
  value Int @default(0)
}
